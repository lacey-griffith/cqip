NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
JIRA_API_TOKEN=
JIRA_EMAIL=
JIRA_BASE_URL=https://fusion92.atlassian.net
TEAMS_WEBHOOK_URL=
WEBHOOK_SECRET=
# Shared secret between Worker and jira-sync edge function. Can be any
# random string — generate with `openssl rand -hex 32`. Not a JWT.
CQIP_SYNC_AUTH_KEY=
# Shared secret for external consumers of the read-only /api/brands
# endpoints (consumed by the Forge QA-automation app). The same value
# must be set as an encrypted Forge variable on the Forge side.
# Generate with `openssl rand -hex 32`.
CQIP_BRANDS_API_TOKEN=
# Shared secret between the daily pg_cron job and the
# drought-evaluator edge function. Generate with `openssl rand -hex 32`.
# Not a JWT.
CQIP_DROUGHT_AUTH_KEY=
# Batch 009 — SharePoint proxy. AC (Forge) ↔ Worker bearer for the
# /api/sharepoint/* routes. Separate from CQIP_BRANDS_API_TOKEN per
# spec §7 / DC §13 r27 so blast radius stays bounded. Generate with
# `openssl rand -hex 32`. Not a JWT.
CQIP_SHAREPOINT_API_TOKEN=
# Batch 012 Phase B — Client Library monitoring ingest. Bearer secret for
# the external POST /api/monitoring/findings feed (Convert 008 and any
# monitoring tool post through it). Separate blast radius per §13 r27.
# Generate with `openssl rand -hex 32`. Not a JWT. Set on the Worker via
# `wrangler secret put` and wherever the monitoring tool runs.
CQIP_CONVERT_MONITORING_TOKEN=
# Batch 009 — Azure AD application credentials for the Microsoft Graph
# client. Set on Worker via `wrangler secret put`. App registration:
# "CQIP Dashboard - SharePoint Integration" (client_id
# 6aa464c1-4eb9-4d94-b087-6eebe4fa8cb6). Admin consent on
# Sites.Selected and per-site CRO grant already in place (verified
# 2026-05-26).
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
# Batch 009 — SharePoint site root for v1. Multi-site would mean
# resolving these per request; spec §12 defers that until a second
# site lands.
SHAREPOINT_SITE_HOSTNAME=fusion92.sharepoint.com
SHAREPOINT_SITE_PATH=/sites/CRO
